# =============================================================================
# 开造 VCC - 环境变量配置模板
# 使用方式: cp .env.example .env && vim .env
# =============================================================================

# ---- 通用配置 ----
APP_ENV=production
APP_VERSION=latest
TZ=Asia/Shanghai

# ---- PostgreSQL ----
POSTGRES_DB=vibebuild
POSTGRES_USER=vibebuild
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_strong_password
REDIS_PORT=6379

# ---- Milvus 依赖 (MinIO) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Milvus ----
MILVUS_PORT=19530
MILVUS_GRPC_PORT=9091

# ---- Elasticsearch ----
ES_PORT=9200

# ---- Go 后端服务 ----
SERVER_PORT=8080
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars_long
JWT_ACCESS_TTL=7200
JWT_REFRESH_TTL=2592000

# ---- Python AI Agent 服务 ----
AI_AGENT_PORT=8000
EMBEDDING_MODEL=bge-m3
AI_RATE_LIMIT_FREE=10
AI_RATE_LIMIT_PRO=100

# ---- LLM API Keys ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=

# ---- 微信开放平台 ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_MCH_API_KEY=
WECHAT_MCH_CERT_PATH=

# ---- 支付宝 ----
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ---- 阿里云 OSS ----
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=vibebuild

# ---- 阿里云短信 ----
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=开造
SMS_TEMPLATE_CODE=

# ---- 极光推送 ----
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# ---- Nginx ----
HTTP_PORT=80
HTTPS_PORT=443
