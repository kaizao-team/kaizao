# ============================================================
# ai-agent 生产环境配置模板
# 实际 .env 由运维手动管理，禁止被 rsync/deploy 脚本覆盖
# ============================================================

# OpenAI GPT（主力 LLM，通过代理）
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_BASE_URL=https://api-vip.codex-for.me/v1
OPENAI_MODEL=gpt-5.4

# 智谱 GLM（降级备选）
ZHIPU_API_KEY=<your-zhipu-api-key>
ZHIPU_MODEL=GLM-4-FlashX

DEBUG=false

# MySQL（生产）
MYSQL_URL=mysql+aiomysql://kaizao:kaizao_prod_2026@kaizao-mysql:3306/kaizao?charset=utf8mb4

# Redis（生产密码：redis123）
REDIS_URL=redis://:redis123@kaizao-redis:6379/0

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

LOG_LEVEL=INFO

# DashScope Embedding
DASHSCOPE_API_KEY=<your-dashscope-api-key>
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
