# 复制到远程 ~/kaizao-server/.env 后，与 docker-compose.prod.yml 同目录执行 compose 时会自动参与变量替换。
# 本地：cp deploy/env.prod.example .env 按需修改后再 push（可选；不复制则使用 compose 内默认值）。

# API 对外根 URL（无尾斜杠），用于上传资源等绝对地址
VB_SERVER_PUBLIC_BASE_URL=http://47.236.165.75:39527

# MinIO 对外访问前缀（须与端口映射、防火墙一致；前置 Nginx/HTTPS 时改为域名）
VB_OSS_BASE_URL=http://47.236.165.75:39000/kaizao

# AI-Agent 基址（无尾斜杠）
VB_AI_AGENT_BASE_URL=http://47.236.165.75:39528

# JWT 密钥（务必替换为强随机串）
VB_JWT_SECRET=请替换为长随机串

# 可选：覆盖数据库/Redis 密码（须与 compose 中 mysql/redis 服务一致）
# MYSQL_ROOT_PASSWORD=
# MYSQL_PASSWORD=
# REDIS_PASSWORD=
