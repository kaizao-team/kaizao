# 复制为 .env.wsl 后按需修改；与 docker-compose.wsl.yml 配合使用：
#   docker compose -f docker-compose.wsl.yml --env-file .env.wsl up -d --build
#
# 端口映射在 docker-compose.wsl.yml 中固定为：MySQL 3306、Redis 6379、MinIO 9000/9001、API 39527。
# 若需只监听本机，请编辑该 yml 中 ports 为 "127.0.0.1:3306:3306" 等形式。

# --- 数据库 ---
# MYSQL_ROOT_PASSWORD=
# MYSQL_PASSWORD=

# --- Redis ---
# REDIS_PASSWORD=

# --- MinIO ---
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# --- API 服务 ---
VB_SERVER_MODE=debug
VB_JWT_SECRET=kaizao-dev-jwt-secret

# 返回给前端的 OSS 访问基址：在 Windows 浏览器访问 WSL 内服务时一般用 localhost
# 若需使用局域网 IP，改为 http://<你的局域网IP>:9000/kaizao
VB_OSS_BASE_URL=http://localhost:9000/kaizao

# 智能匹配 Agent（无服务可留默认或注释掉由代码处理）
VB_AI_AGENT_BASE_URL=http://47.236.165.75:39528

# debug 下无 RSA 文件时自动生成密钥
VB_AUTH_PASSWORD_DEV_AUTO_KEY=1
